# Switchboard — environment. Copy to `.env` and fill in to run LIVE.
# With NONE of these set, the agent runs fully offline (deterministic extractor
# + local SQLite Notion mirror) so the demo and tests work with zero keys.

# --- Claude (Anthropic track): the reasoning / extraction core ---
ANTHROPIC_API_KEY=
SWITCHBOARD_MODEL=claude-3-5-sonnet-latest

# --- Notion (Notion track): the database the job records land in ---
NOTION_TOKEN=
NOTION_DB_ID=

# --- Local state (optional overrides) ---
SWITCHBOARD_DB=switchboard.db
SWITCHBOARD_MIRROR=switchboard_notion_mirror.db
